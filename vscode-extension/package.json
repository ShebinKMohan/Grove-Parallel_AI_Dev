{
  "name": "grove-pilot",
  "displayName": "Grove — Worktree Control for Claude Code",
  "description": "Control plane for parallel AI development — git worktree management, Claude Code session orchestration, and merge intelligence",
  "version": "0.3.1",
  "publisher": "ShebinMohanK",
  "author": {
    "name": "Shebin K Mohan",
    "url": "https://github.com/ShebinKMohan"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShebinKMohan/Grove"
  },
  "homepage": "https://github.com/ShebinKMohan/Grove#readme",
  "bugs": {
    "url": "https://github.com/ShebinKMohan/Grove/issues"
  },
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "git",
    "worktree",
    "claude",
    "claude code",
    "parallel development",
    "AI agents",
    "agent teams",
    "AI coding",
    "merge",
    "orchestration"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "grove.createWorktree",
        "title": "Create Worktree",
        "category": "Grove",
        "icon": "$(add)"
      },
      {
        "command": "grove.deleteWorktree",
        "title": "Delete Worktree",
        "category": "Grove",
        "icon": "$(trash)"
      },
      {
        "command": "grove.cleanupWorktrees",
        "title": "Cleanup Stale Worktrees",
        "category": "Grove",
        "icon": "$(trash)"
      },
      {
        "command": "grove.launchSession",
        "title": "Launch Claude Code in Worktree",
        "category": "Grove",
        "icon": "$(rocket)"
      },
      {
        "command": "grove.openDashboard",
        "title": "Open Dashboard",
        "category": "Grove",
        "icon": "$(dashboard)"
      },
      {
        "command": "grove.openInTerminal",
        "title": "Open in Terminal",
        "category": "Grove",
        "icon": "$(terminal)"
      },
      {
        "command": "grove.openInNewWindow",
        "title": "Open in New Window",
        "category": "Grove",
        "icon": "$(multiple-windows)"
      },
      {
        "command": "grove.viewDiff",
        "title": "View Diff",
        "category": "Grove",
        "icon": "$(diff)"
      },
      {
        "command": "grove.stopSession",
        "title": "Stop Session",
        "category": "Grove",
        "icon": "$(debug-stop)"
      },
      {
        "command": "grove.stopAllSessions",
        "title": "Stop All Sessions",
        "category": "Grove",
        "icon": "$(debug-stop)"
      },
      {
        "command": "grove.focusSession",
        "title": "Open Session Terminal",
        "category": "Grove",
        "icon": "$(terminal)"
      },
      {
        "command": "grove.setTaskDescription",
        "title": "Set Task Description",
        "category": "Grove",
        "icon": "$(edit)"
      },
      {
        "command": "grove.clearCompletedSessions",
        "title": "Clear Completed Sessions",
        "category": "Grove",
        "icon": "$(clear-all)"
      },
      {
        "command": "grove.refreshSidebar",
        "title": "Refresh",
        "category": "Grove",
        "icon": "$(refresh)"
      },
      {
        "command": "grove.launchTeam",
        "title": "Launch Agent Team",
        "category": "Grove",
        "icon": "$(organization)"
      },
      {
        "command": "grove.stopTeam",
        "title": "Stop Team",
        "category": "Grove",
        "icon": "$(debug-stop)"
      },
      {
        "command": "grove.stopAgent",
        "title": "Stop Agent",
        "category": "Grove",
        "icon": "$(debug-stop)"
      },
      {
        "command": "grove.focusAgent",
        "title": "Open Agent Terminal",
        "category": "Grove",
        "icon": "$(terminal)"
      },
      {
        "command": "grove.cleanupTeam",
        "title": "Cleanup Team Worktrees",
        "category": "Grove",
        "icon": "$(trash)"
      },
      {
        "command": "grove.runOverlapCheck",
        "title": "Check File Overlaps",
        "category": "Grove",
        "icon": "$(shield)"
      },
      {
        "command": "grove.generateMergeReport",
        "title": "Generate Merge Report",
        "category": "Grove",
        "icon": "$(checklist)"
      },
      {
        "command": "grove.executeMergeSequence",
        "title": "Execute Merge Sequence",
        "category": "Grove",
        "icon": "$(merge)"
      },
      {
        "command": "grove.syncWorktree",
        "title": "Sync from Remote",
        "category": "Grove",
        "icon": "$(cloud-download)"
      },
      {
        "command": "grove.quickMenu",
        "title": "Quick Menu",
        "category": "Grove",
        "icon": "$(layers)"
      },
      {
        "command": "grove.addToWorkspace",
        "title": "Show in Explorer",
        "category": "Grove",
        "icon": "$(folder-opened)"
      },
      {
        "command": "grove.removeFromWorkspace",
        "title": "Hide from Explorer",
        "category": "Grove",
        "icon": "$(folder)"
      },
      {
        "command": "grove.openFileDiff",
        "title": "Show Diff",
        "category": "Grove",
        "icon": "$(diff)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "grove",
          "title": "Grove",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "grove": [
        {
          "id": "grove.explorer",
          "name": "Grove",
          "contextualTitle": "Grove",
          "visibility": "visible"
        },
        {
          "id": "grove.completed",
          "name": "Completed",
          "contextualTitle": "Completed Sessions & Teams",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "grove.explorer",
        "contents": "Welcome to Grove!\n\nGet started with parallel AI development:\n\n[Create Worktree](command:grove.createWorktree)\n[Launch Agent Team](command:grove.launchTeam)\n[Open Dashboard](command:grove.openDashboard)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "grove.createWorktree",
          "when": "view == grove.explorer",
          "group": "navigation@1"
        },
        {
          "command": "grove.launchTeam",
          "when": "view == grove.explorer",
          "group": "navigation@2"
        },
        {
          "command": "grove.openDashboard",
          "when": "view == grove.explorer",
          "group": "navigation@3"
        },
        {
          "command": "grove.clearCompletedSessions",
          "when": "view == grove.completed",
          "group": "navigation@1"
        },
        {
          "command": "grove.refreshSidebar",
          "when": "view == grove.explorer",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "grove.launchSession",
          "when": "viewItem == worktree || viewItem == worktree-main",
          "group": "inline@1"
        },
        {
          "command": "grove.syncWorktree",
          "when": "viewItem == worktree || viewItem == worktree-main || viewItem == worktree-with-session",
          "group": "inline@2"
        },
        {
          "command": "grove.openInTerminal",
          "when": "viewItem == worktree || viewItem == worktree-main || viewItem == worktree-with-session",
          "group": "inline@3"
        },
        {
          "command": "grove.openInNewWindow",
          "when": "viewItem == worktree || viewItem == worktree-main || viewItem == worktree-with-session",
          "group": "1_open"
        },
        {
          "command": "grove.launchSession",
          "when": "viewItem == worktree || viewItem == worktree-main",
          "group": "1_open"
        },
        {
          "command": "grove.syncWorktree",
          "when": "viewItem == worktree || viewItem == worktree-main || viewItem == worktree-with-session",
          "group": "2_inspect"
        },
        {
          "command": "grove.viewDiff",
          "when": "viewItem == worktree || viewItem == worktree-main || viewItem == worktree-with-session",
          "group": "2_inspect"
        },
        {
          "command": "grove.addToWorkspace",
          "when": "viewItem == worktree || viewItem == worktree-with-session",
          "group": "1_open"
        },
        {
          "command": "grove.deleteWorktree",
          "when": "viewItem == worktree || viewItem == worktree-with-session",
          "group": "3_manage"
        },
        {
          "command": "grove.focusSession",
          "when": "viewItem == session-active",
          "group": "inline@1"
        },
        {
          "command": "grove.stopSession",
          "when": "viewItem == session-active",
          "group": "inline@2"
        },
        {
          "command": "grove.setTaskDescription",
          "when": "viewItem == session-active || viewItem == session-completed",
          "group": "1_session"
        },
        {
          "command": "grove.stopTeam",
          "when": "viewItem == team-active",
          "group": "inline@1"
        },
        {
          "command": "grove.cleanupTeam",
          "when": "viewItem == team-completed",
          "group": "inline@1"
        },
        {
          "command": "grove.stopTeam",
          "when": "viewItem == team-active",
          "group": "1_team"
        },
        {
          "command": "grove.cleanupTeam",
          "when": "viewItem == team-active || viewItem == team-completed",
          "group": "2_team"
        },
        {
          "command": "grove.focusAgent",
          "when": "viewItem == agent-active",
          "group": "inline@1"
        },
        {
          "command": "grove.stopAgent",
          "when": "viewItem == agent-active",
          "group": "inline@2"
        },
        {
          "command": "grove.cleanupTeam",
          "when": "viewItem == team-completed && view == grove.completed",
          "group": "inline@1"
        }
      ],
      "commandPalette": [
        {
          "command": "grove.syncWorktree",
          "when": "false"
        },
        {
          "command": "grove.openInTerminal",
          "when": "false"
        },
        {
          "command": "grove.openInNewWindow",
          "when": "false"
        },
        {
          "command": "grove.launchSession",
          "when": "false"
        },
        {
          "command": "grove.deleteWorktree",
          "when": "false"
        },
        {
          "command": "grove.viewDiff",
          "when": "false"
        },
        {
          "command": "grove.refreshSidebar",
          "when": "false"
        },
        {
          "command": "grove.stopSession",
          "when": "false"
        },
        {
          "command": "grove.focusSession",
          "when": "false"
        },
        {
          "command": "grove.setTaskDescription",
          "when": "false"
        },
        {
          "command": "grove.clearCompletedSessions",
          "when": "false"
        },
        {
          "command": "grove.stopTeam",
          "when": "false"
        },
        {
          "command": "grove.stopAgent",
          "when": "false"
        },
        {
          "command": "grove.focusAgent",
          "when": "false"
        },
        {
          "command": "grove.cleanupTeam",
          "when": "false"
        },
        {
          "command": "grove.addToWorkspace",
          "when": "false"
        },
        {
          "command": "grove.removeFromWorkspace",
          "when": "false"
        },
        {
          "command": "grove.openFileDiff",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Grove",
      "properties": {
        "grove.defaultBaseBranch": {
          "type": "string",
          "default": "main",
          "description": "Default base branch for comparisons and new worktrees"
        },
        "grove.autoInstallDependencies": {
          "type": "boolean",
          "default": true,
          "description": "Automatically install dependencies after creating a worktree"
        },
        "grove.packageManager": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "npm",
            "yarn",
            "pnpm",
            "pip",
            "pipenv",
            "poetry"
          ],
          "description": "Package manager to use for dependency installation"
        },
        "grove.worktreeLocation": {
          "type": "string",
          "default": ".claude/worktrees",
          "description": "Directory for worktrees relative to the repo root"
        },
        "grove.enableAgentTeams": {
          "type": "boolean",
          "default": true,
          "description": "Enable Agent Teams features (sets CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS)"
        },
        "grove.templateDirectory": {
          "type": "string",
          "default": ".grove/templates",
          "description": "Directory for team templates relative to the repo root"
        },
        "grove.testCommand": {
          "type": "string",
          "default": "",
          "description": "Test command to run after merges (auto-detected from package.json if empty)"
        },
        "grove.maxConcurrentSessions": {
          "type": "number",
          "default": 5,
          "description": "Maximum number of concurrent Claude Code sessions"
        },
        "grove.showTokenEstimates": {
          "type": "boolean",
          "default": true,
          "description": "Show estimated token cost before launching teams"
        },
        "grove.fileWatcherDebounce": {
          "type": "number",
          "default": 500,
          "description": "Debounce interval in ms for file change events"
        },
        "grove.notifyOnSessionComplete": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when a Claude Code session completes"
        },
        "grove.autoGitignore": {
          "type": "boolean",
          "default": true,
          "description": "Automatically add worktree paths to .gitignore"
        },
        "grove.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show worktree info in the status bar"
        },
        "grove.protectedBranches": {
          "type": "array",
          "default": [
            "main",
            "master",
            "develop",
            "production"
          ],
          "description": "Branches that cannot be deleted during cleanup"
        }
      }
    }
  },
  "scripts": {
    "postinstall": "cd webview-ui && npm install",
    "compile": "npm run build:webview && tsc -p ./",
    "compile:ext": "tsc -p ./",
    "build:webview": "cd webview-ui && npm run build",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npx vitest run",
    "test:integration": "npm run compile && node ./out/test/runTest.js",
    "package": "npm run compile && npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.0"
  }
}
